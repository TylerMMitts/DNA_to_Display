# Ignore dataset contents but keep the folder structure
dataset/images/*
dataset/metadata/*
!dataset/images/.gitkeep
!dataset/metadata/.gitkeep

# Ignore results contents but keep the folder structure
results/*
!results/.gitkeep

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# Jupyter notebooks
.ipynb_checkpoints/
*.ipynb

# IDE files
.vscode/
.idea/
*.swp
*.swo